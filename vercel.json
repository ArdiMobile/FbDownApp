{
  "builds": [
    { 
      "src": "api/index.py", 
      "use": "@vercel/python",
      "config": {
        "installCommand": "python -m pip install --upgrade pip && pip install -r requirements.txt"
      }
    },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/info", "destination": "/api/index.py" }
  ]
}